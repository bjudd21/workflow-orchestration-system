    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\n<html>\n<head>\n  <title>PRD Interview</title>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <script src=\"https://unpkg.com/alpinejs@3.13.5/dist/cdn.min.js\" defer></script>\n  <script src=\"https://unpkg.com/htmx.org@1.9.10\"></script>\n  <style>\n    * { box-sizing: border-box; }\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      max-width: 900px;\n      margin: 0 auto;\n      padding: 20px;\n      background: #f5f5f5;\n    }\n    h2 { color: #333; margin-bottom: 4px; }\n    .subtitle { color: #666; font-size: 14px; margin-bottom: 16px; }\n    .project-row { display: flex; gap: 8px; align-items: center; margin-bottom: 12px; }\n    .project-row label { font-size: 14px; font-weight: 600; }\n    .project-row input {\n      border: 1px solid #ccc;\n      border-radius: 4px;\n      padding: 6px 10px;\n      font-size: 14px;\n      width: 200px;\n    }\n\n    /* Phase Container */\n    .phase-container {\n      background: white;\n      border: 1px solid #ddd;\n      border-radius: 8px;\n      padding: 20px;\n      margin-bottom: 16px;\n    }\n\n    /* Interview Chat UI */\n    #messages {\n      background: white;\n      border: 1px solid #ddd;\n      border-radius: 8px;\n      padding: 16px;\n      height: 420px;\n      overflow-y: auto;\n      margin-bottom: 12px;\n    }\n    .msg { margin-bottom: 12px; }\n    .user-msg { text-align: right; }\n    .user-msg .bubble {\n      display: inline-block;\n      background: #0071e3;\n      color: white;\n      padding: 8px 14px;\n      border-radius: 16px 16px 4px 16px;\n      max-width: 85%;\n      font-size: 14px;\n    }\n    .agent-msg .bubble {\n      display: inline-block;\n      background: #f0f0f0;\n      color: #222;\n      padding: 10px 14px;\n      border-radius: 4px 16px 16px 16px;\n      max-width: 90%;\n      font-size: 14px;\n      white-space: pre-wrap;\n      word-break: break-word;\n    }\n    .agent-label {\n      font-size: 11px;\n      color: #888;\n      margin-bottom: 3px;\n      font-weight: 600;\n      letter-spacing: 0.5px;\n      text-transform: uppercase;\n    }\n    .complete-banner {\n      background: #d4edda;\n      border: 1px solid #c3e6cb;\n      color: #155724;\n      padding: 12px 16px;\n      border-radius: 6px;\n      margin-top: 8px;\n      font-size: 14px;\n    }\n    .error-banner {\n      background: #f8d7da;\n      border: 1px solid #f5c6cb;\n      color: #721c24;\n      padding: 12px 16px;\n      border-radius: 6px;\n      margin-top: 8px;\n      font-size: 14px;\n    }\n    .input-row { display: flex; gap: 8px; }\n    #message-input {\n      flex: 1;\n      border: 1px solid #ccc;\n      border-radius: 20px;\n      padding: 10px 16px;\n      font-size: 14px;\n      outline: none;\n    }\n    #message-input:focus { border-color: #0071e3; }\n    .thinking { color: #888; font-style: italic; font-size: 13px; }\n\n    /* Progress Bar Component */\n    .progress-container { text-align: center; }\n    .progress-label {\n      font-size: 14px;\n      font-weight: 600;\n      margin-bottom: 8px;\n      color: #333;\n    }\n    .progress-bar-bg {\n      width: 100%;\n      height: 24px;\n      background: #e0e0e0;\n      border-radius: 12px;\n      overflow: hidden;\n      margin-bottom: 8px;\n    }\n    .progress-bar-fill {\n      height: 100%;\n      background: linear-gradient(90deg, #34c759 0%, #30d158 100%);\n      transition: width 0.5s ease;\n      display: flex;\n      align-items: center;\n      justify-content: flex-end;\n      padding-right: 8px;\n      color: white;\n      font-weight: 600;\n      font-size: 12px;\n    }\n    .progress-message {\n      font-size: 13px;\n      color: #666;\n      font-style: italic;\n    }\n\n    /* Council Stream Component */\n    .council-stream {\n      max-height: 500px;\n      overflow-y: auto;\n    }\n    .council-review {\n      border-left: 3px solid #0071e3;\n      padding: 12px 16px;\n      margin-bottom: 16px;\n      background: #f9f9f9;\n      border-radius: 4px;\n      animation: fadeIn 0.5s ease;\n    }\n    .council-review.pending {\n      border-left-color: #ffa500;\n      background: #fff8e1;\n    }\n    .council-review-header {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      margin-bottom: 8px;\n    }\n    .reviewer-name {\n      font-weight: 600;\n      font-size: 15px;\n      color: #333;\n    }\n    .reviewer-verdict {\n      padding: 3px 10px;\n      border-radius: 12px;\n      font-size: 12px;\n      font-weight: 600;\n    }\n    .reviewer-verdict.APPROVE { background: #d4edda; color: #155724; }\n    .reviewer-verdict.CONCERNS { background: #fff3cd; color: #856404; }\n    .reviewer-verdict.REJECT { background: #f8d7da; color: #721c24; }\n    .review-content {\n      font-size: 14px;\n      color: #555;\n      white-space: pre-wrap;\n      line-height: 1.5;\n    }\n    @keyframes fadeIn {\n      from { opacity: 0; transform: translateY(10px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n\n    /* Findings Component */\n    .findings-verdict {\n      text-align: center;\n      padding: 20px;\n      margin-bottom: 20px;\n      border-radius: 8px;\n    }\n    .findings-verdict.APPROVED { background: #d4edda; color: #155724; }\n    .findings-verdict.CONCERNS { background: #fff3cd; color: #856404; }\n    .findings-verdict.REVISE { background: #f8d7da; color: #721c24; }\n    .findings-verdict h3 { margin: 0 0 8px 0; font-size: 20px; }\n    .findings-verdict p { margin: 0; font-size: 14px; }\n    .findings-summary {\n      background: #f9f9f9;\n      padding: 16px;\n      border-radius: 6px;\n      margin-bottom: 20px;\n      font-size: 14px;\n      line-height: 1.6;\n      white-space: pre-wrap;\n    }\n    .action-buttons {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 12px;\n    }\n\n    /* Buttons */\n    button, .btn {\n      background: #0071e3;\n      color: white;\n      border: none;\n      border-radius: 8px;\n      padding: 12px 20px;\n      font-size: 14px;\n      font-weight: 600;\n      cursor: pointer;\n      white-space: nowrap;\n      transition: background 0.2s;\n    }\n    button:hover, .btn:hover { background: #005bbf; }\n    button:disabled, .btn:disabled { background: #aaa; cursor: default; }\n    .btn-success { background: #34c759; }\n    .btn-success:hover { background: #30b350; }\n    .btn-danger { background: #ff3b30; }\n    .btn-danger:hover { background: #e02020; }\n    .btn-warning { background: #ff9500; }\n    .btn-warning:hover { background: #e08000; }\n    .btn-secondary { background: #8e8e93; }\n    .btn-secondary:hover { background: #6e6e73; }\n\n    /* Connection Status */\n    .connection-status {\n      position: fixed;\n      top: 10px;\n      right: 10px;\n      padding: 8px 16px;\n      border-radius: 20px;\n      font-size: 12px;\n      font-weight: 600;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n    }\n    .connection-status.connected { background: #d4edda; color: #155724; }\n    .connection-status.disconnected { background: #f8d7da; color: #721c24; }\n    .connection-status.reconnecting { background: #fff3cd; color: #856404; }\n\n    /* Alpine.js handles visibility with x-show, no CSS override needed */\n    /* x-cloak hides content until Alpine.js fully initializes */\n    [x-cloak] { display: none !important; }\n\n    /* Responsive */\n    @media (max-width: 768px) {\n      .action-buttons { grid-template-columns: 1fr; }\n      body { padding: 12px; }\n    }\n  </style>\n</head>\n<body x-data=\"pipelineState()\" x-cloak>\n\n  <!-- Connection Status Indicator -->\n  <div class=\"connection-status\"\n       :class=\"connectionStatus\"\n       x-show=\"currentPhase !== 'interview'\"\n       x-text=\"connectionStatus === 'connected' ? '\ud83d\udfe2 Live' :\n               connectionStatus === 'reconnecting' ? '\ud83d\udfe1 Reconnecting...' :\n               '\ud83d\udd34 Disconnected'\">\n  </div>\n\n  <h2>PRD Workflow Pipeline</h2>\n  <p class=\"subtitle\">Interactive requirements gathering \u2192 PRD synthesis \u2192 council review</p>\n\n  <div class=\"project-row\">\n    <label for=\"project\">Project:</label>\n    <input id=\"project\" type=\"text\" placeholder=\"my-project\" x-model=\"projectName\">\n  </div>\n\n  <!-- Phase 1: Interview -->\n  <div x-show=\"currentPhase === 'interview'\" class=\"phase-container\">\n    <div id=\"messages\"></div>\n    <div class=\"input-row\">\n      <input id=\"message-input\" type=\"text\" placeholder=\"Type your response...\" x-ref=\"messageInput\">\n      <button id=\"send-btn\" @click=\"sendMessage()\" :disabled=\"interviewComplete\">Send</button>\n    </div>\n  </div>\n\n  <!-- Phase 2: Progress Bar (PRD Synthesis) -->\n  <div x-show=\"currentPhase === 'synthesis'\" class=\"phase-container\">\n    <div class=\"progress-container\">\n      <div class=\"progress-label\">Phase 3: PRD Synthesis</div>\n      <div class=\"progress-bar-bg\">\n        <div class=\"progress-bar-fill\" :style=\"`width: ${progressPercent}%`\">\n          <span x-text=\"progressPercent + '%'\"></span>\n        </div>\n      </div>\n      <div class=\"progress-message\" x-text=\"progressMessage\"></div>\n    </div>\n  </div>\n\n  <!-- Phase 3: Council Review Stream -->\n  <div x-show=\"currentPhase === 'council'\" class=\"phase-container\">\n    <h3 style=\"margin-top: 0;\">Phase 4: Council Review</h3>\n    <div class=\"council-stream\">\n      <template x-for=\"review in councilReviews\" :key=\"review.name\">\n        <div class=\"council-review\" :class=\"{ 'pending': review.pending }\">\n          <div class=\"council-review-header\">\n            <div class=\"reviewer-name\" x-text=\"review.name\"></div>\n            <div class=\"reviewer-verdict\"\n                 :class=\"review.verdict\"\n                 x-show=\"!review.pending\"\n                 x-text=\"review.verdict\">\n            </div>\n          </div>\n          <div class=\"review-content\" x-text=\"review.content\"></div>\n        </div>\n      </template>\n    </div>\n  </div>\n\n  <!-- Phase 4: Findings & Actions -->\n  <div x-show=\"currentPhase === 'findings'\" class=\"phase-container\">\n    <div class=\"findings-verdict\"\n         :class=\"findings.verdict === 'APPROVED' ? 'APPROVED' :\n                 findings.verdict === 'APPROVED WITH CONCERNS' ? 'CONCERNS' :\n                 'REVISE'\">\n      <h3 x-text=\"findings.verdict\"></h3>\n      <p>\n        <span x-text=\"findings.concerns\"></span> concern(s) raised \u2022\n        <span x-text=\"findings.endorsements\"></span> endorsement(s)\n      </p>\n    </div>\n\n    <div class=\"findings-summary\" x-text=\"findings.summary\"></div>\n\n    <div class=\"action-buttons\">\n      <button class=\"btn btn-success\" @click=\"approveAndProceed()\">\n        \u2713 Approve & Proceed\n      </button>\n      <button class=\"btn btn-danger\" @click=\"rejectPRD()\">\n        \u2717 Reject PRD\n      </button>\n      <button class=\"btn btn-warning\" @click=\"revisePRD()\">\n        \u21bb Request Revision\n      </button>\n      <button class=\"btn btn-secondary\" @click=\"generateTasksAnyway()\">\n        \u2192 Generate Tasks Anyway\n      </button>\n    </div>\n  </div>\n\n  <script>\n    function pipelineState() {\n      return {\n        // State\n        currentPhase: 'interview', // interview | synthesis | council | findings\n        projectName: '',\n        interviewComplete: false,\n        progressPercent: 0,\n        progressMessage: 'Waiting...',\n        councilReviews: [],\n        findings: {\n          verdict: '',\n          concerns: 0,\n          endorsements: 0,\n          summary: ''\n        },\n        connectionStatus: 'disconnected', // connected | disconnected | reconnecting\n        eventSource: null,\n\n        // Initialize\n        init() {\n          // Set default project name\n          const urlParams = new URLSearchParams(window.location.search);\n          const urlProject = urlParams.get('project');\n          if (urlProject) {\n            this.projectName = urlProject;\n          } else {\n            const now = new Date();\n            const dateStr = now.toISOString().slice(0, 10);\n            const timeStr = now.toTimeString().slice(0, 5).replace(':', '');\n            this.projectName = `project-${dateStr}-${timeStr}`;\n          }\n\n          // Start interview\n          this.startInterview();\n        },\n\n        // Interview Methods\n        async startInterview() {\n          try {\n            const r = await fetch('/webhook/prd-interview-send', {\n              method: 'POST',\n              headers: {'Content-Type': 'application/json'},\n              body: JSON.stringify({\n                project: this.projectName,\n                message: '__START__'\n              })\n            });\n            const d = await r.json();\n            if (!d.error) this.addMsg(d.response, 'agent');\n          } catch(e) {\n            this.addMsg('Failed to start interview: ' + e.message, 'agent');\n          }\n        },\n\n        async sendMessage() {\n          if (this.interviewComplete) return;\n\n          const inp = this.$refs.messageInput;\n          const msg = inp.value.trim();\n          if (!msg) return;\n\n          this.addMsg(msg, 'user');\n          inp.value = '';\n\n          const thinking = document.createElement('div');\n          thinking.className = 'msg agent-msg';\n          thinking.innerHTML = '<div class=\"bubble thinking\">Thinking...</div>';\n          document.getElementById('messages').appendChild(thinking);\n\n          try {\n            const r = await fetch('/webhook/prd-interview-send', {\n              method: 'POST',\n              headers: {'Content-Type': 'application/json'},\n              body: JSON.stringify({\n                project: this.projectName,\n                message: msg\n              })\n            });\n            const d = await r.json();\n            thinking.remove();\n\n            if (d.error) {\n              const e = document.createElement('div');\n              e.className = 'error-banner';\n              e.textContent = 'Error: ' + d.error;\n              document.getElementById('messages').appendChild(e);\n            } else {\n              this.addMsg(d.response, 'agent');\n\n              if (d.complete) {\n                this.interviewComplete = true;\n                const banner = document.createElement('div');\n                banner.className = 'complete-banner';\n                banner.textContent = 'Interview complete! Transitioning to PRD synthesis...';\n                document.getElementById('messages').appendChild(banner);\n\n                // Transition to synthesis phase after 2 seconds\n                setTimeout(() => {\n                  this.currentPhase = 'synthesis';\n                  this.connectSSE();\n                }, 2000);\n              } else {\n                inp.focus();\n              }\n            }\n          } catch(e) {\n            thinking.remove();\n            this.addMsg('Network error: ' + e.message, 'agent');\n          }\n        },\n\n        addMsg(text, who) {\n          const box = document.getElementById('messages');\n          const wrap = document.createElement('div');\n          wrap.className = 'msg ' + (who === 'user' ? 'user-msg' : 'agent-msg');\n          if (who === 'agent') {\n            const lbl = document.createElement('div');\n            lbl.className = 'agent-label';\n            lbl.textContent = 'PRD Interviewer';\n            wrap.appendChild(lbl);\n          }\n          const b = document.createElement('div');\n          b.className = 'bubble';\n          b.textContent = text;\n          wrap.appendChild(b);\n          box.appendChild(wrap);\n          box.scrollTop = box.scrollHeight;\n        },\n\n        // SSE Connection\n        connectSSE() {\n          if (this.eventSource) return; // Already connected\n\n          this.connectionStatus = 'reconnecting';\n          this.eventSource = new EventSource(`http://localhost:3001/events/${this.projectName}`);\n\n          this.eventSource.addEventListener('connected', (e) => {\n            console.log('SSE connected:', e.data);\n            this.connectionStatus = 'connected';\n          });\n\n          this.eventSource.addEventListener('phase3.progress', (e) => {\n            const data = JSON.parse(e.data);\n            this.progressPercent = parseInt(data.percent);\n            this.progressMessage = data.message;\n\n            // Transition to council when synthesis complete\n            if (this.progressPercent === 100) {\n              setTimeout(() => {\n                this.currentPhase = 'council';\n                this.initializeCouncilReviews();\n              }, 1500);\n            }\n          });\n\n          this.eventSource.addEventListener('phase4.reviewer', (e) => {\n            const data = JSON.parse(e.data);\n            const review = this.councilReviews.find(r => r.name === data.reviewer);\n            if (review) {\n              review.pending = false;\n              review.verdict = data.verdict;\n              review.content = data.review;\n            }\n\n            // Auto-scroll to bottom\n            setTimeout(() => {\n              const stream = document.querySelector('.council-stream');\n              if (stream) stream.scrollTop = stream.scrollHeight;\n            }, 100);\n          });\n\n          this.eventSource.addEventListener('phase4.complete', (e) => {\n            const data = JSON.parse(e.data);\n            this.findings.verdict = data.verdict;\n            this.findings.concerns = data.concerns || 0;\n            this.findings.endorsements = data.endorsements || 0;\n            this.findings.summary = data.summary;\n\n            // Transition to findings after 2 seconds\n            setTimeout(() => {\n              this.currentPhase = 'findings';\n              this.eventSource.close();\n              this.connectionStatus = 'disconnected';\n            }, 2000);\n          });\n\n          this.eventSource.onerror = (e) => {\n            console.error('SSE error:', e);\n            this.connectionStatus = 'reconnecting';\n          };\n        },\n\n        initializeCouncilReviews() {\n          this.councilReviews = [\n            { name: 'Tech Reviewer', pending: true, verdict: '', content: '\u23f3 Technical Reviewer is reviewing...' },\n            { name: 'Security Reviewer', pending: true, verdict: '', content: '\u23f3 Security Reviewer is reviewing...' },\n            { name: 'Executive Reviewer', pending: true, verdict: '', content: '\u23f3 Executive Reviewer is reviewing...' },\n            { name: 'User Advocate', pending: true, verdict: '', content: '\u23f3 User Advocate is reviewing...' },\n            { name: 'Council Chair', pending: true, verdict: '', content: '\u23f3 Council Chair is deliberating...' }\n          ];\n        },\n\n        // Action Methods\n        async approveAndProceed() {\n          alert('Approve & Proceed: This would trigger Phase 5 (Task Generation).\\nPhase 5 is not yet implemented.');\n          // TODO: POST to /webhook/task-generation-action when Phase 5 exists\n        },\n\n        async rejectPRD() {\n          if (!confirm('Are you sure you want to reject this PRD? This will stop the pipeline.')) return;\n          alert('PRD rejected. Pipeline stopped.');\n          // TODO: Log rejection, stop pipeline\n        },\n\n        async revisePRD() {\n          const feedback = prompt('Enter revision feedback for the PRD Writer:');\n          if (!feedback) return;\n\n          alert('Revision request submitted. This would trigger Phase 3 with feedback.\\nNot yet implemented.');\n          // TODO: POST to /webhook/prd-synthesis-action with feedback\n        },\n\n        async generateTasksAnyway() {\n          if (!confirm('Generate tasks despite concerns? This may result in incomplete task breakdown.')) return;\n          alert('Generating tasks with override flag.\\nPhase 5 is not yet implemented.');\n          // TODO: POST to /webhook/task-generation-action with override flag\n        }\n      };\n    }\n\n    // Auto-submit on Enter key\n    document.addEventListener('alpine:init', () => {\n      document.addEventListener('keypress', (e) => {\n        if (e.key === 'Enter' && e.target.id === 'message-input') {\n          const alpineData = Alpine.$data(document.body);\n          if (alpineData) alpineData.sendMessage();\n        }\n      });\n    });\n  </script>\n</body>\n</html>\n",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "text/html; charset=utf-8"
              }
            ]
          }
        }
      },
