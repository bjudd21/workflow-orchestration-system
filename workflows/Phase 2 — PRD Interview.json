        "responseBody": "={{ JSON.stringify({ response: $(\"Code - Process Response\").first().json.response, complete: true, handoff_path: $(\"Code - Format Handoff\").first().json.handoff_path, project: $(\"Code - Format Handoff\").first().json.project }) }}",
